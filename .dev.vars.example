# Copy to .dev.vars and set your secrets for local dev (wrangler dev).
# .dev.vars is gitignored; never commit real secrets.

# Required for POST /api/admin/command (X-Admin-Key header).
ADMIN_SECRET=your-admin-secret-here

# Optional: for POST /api/character/reset with body {"username":"..."}.
# RESET_SECRET=your-reset-secret-here
